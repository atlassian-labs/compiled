{
  "compilerOptions": {
    "noEmit": true,
    "module": "esnext",
    "target": "es2019",
    "strict": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@compiled/react",
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "skipLibCheck": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@compiled/react": ["./node_modules/@compiled/react/dist/esm/index.d.ts"],
      "@compiled/react/jsx-runtime": ["./node_modules/@compiled/react/dist/esm/jsx/jsx-runtime.d.ts"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"]
    }
  },
  "include": ["class-component-props.test.tsx"]
}
